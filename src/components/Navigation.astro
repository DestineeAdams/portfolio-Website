---

---

<nav class="">
    <div class="mx-auto max-w-7xl px-2 sm:px-6 lg:px-8">
        <div class="relative flex h-16 items-center justify-between">
            <div class="absolute inset-y-0 left-0 flex items-center sm:hidden">
                <!-- Mobile menu button-->
                <button type="button"
                    class="relative inline-flex items-center justify-center rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-white"
                    aria-controls="mobile-menu" aria-expanded="false">
                    <span class="absolute -inset-0.5"></span>
                    <span class="sr-only">Open main menu</span>
                    <!--
              Icon when menu is closed.
  
              Menu open: "hidden", Menu closed: "block"
            -->
                    <svg class="block h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                        aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                    </svg>
                    <!--
              Icon when menu is open.
  
              Menu open: "block", Menu closed: "hidden"
            -->
                    <svg class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
                        aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <div class="flex flex-1 items-center justify-center sm:items-stretch sm:justify-start">

                <div class="flex flex-shrink-0 items-center">
                    <img class="h-8 w-auto" src="public/favicon.ico" alt="logo">
                </div>

                <div class="hidden sm:ml-6 sm:block">
                    <div class="flex space-x-4">
                        <a href="#intro"
                            class="rounded-md px-3 py-2 text-sm font-medium">Intro</a>
                        <a href="#project"
                            class="rounded-md px-3 py-2 text-sm font-medium">Projects</a>
                        <a href="#resume"
                            class="rounded-md px-3 py-2 text-sm font-medium">Resume</a>
                        <a href="#contact"
                            class="rounded-md px-3 py-2 text-sm font-medium">Conact</a>
                        <a href="/art"
                            class="rounded-md px-3 py-2 text-sm font-medium">Art</a>
                        <a href="/blog"
                            class="rounded-md px-3 py-2 text-sm font-medium">Blog</a>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Mobile menu, show/hide based on menu state. -->
    <div class="sm:hidden" id="mobile-menu">
        <div class="space-y-1 px-2 pb-3 pt-2">
            <!-- Current: "bg-gray-900 text-white", Default: "text-gray-300 hover:bg-gray-700 hover:text-white" -->

            <a href="#"
                class="block rounded-md px-3 py-2 text-base font-medium">Intro</a>
            <a href="#"
                class="block rounded-md px-3 py-2 text-base font-medium">Projects</a>
            <a href="#"
                class="block rounded-md px-3 py-2 text-base font-medium">Resume</a>
            <a href="#"
                class="block rounded-md px-3 py-2 text-base font-medium">Conact</a>
            <a href="#"
                class="block rounded-md px-3 py-2 text-base font-medium">Art</a>
            <a href="#"
                class="block rounded-md px-3 py-2 text-base font-medium">Blog</a>
        </div>

    </div>
</nav>



<style>
    nav {
        background-color: #b07bf0;
    }


    a:hover {
        background-color: #ffffff;
        color: #242323;
    }
    
    
</style>