---
import Card from '../components/Card.astro';
import ButtonComp from '../components/ButtonComp.astro';
import Navigation from '../components/Navigation.astro';
import form from '../layouts/form.astro';
import '../styles/gobal.css';
---

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <!-- <link rel="shortcut icon" type="ico" href="favicon.ico" /> -->

    <title>semii dot space</title>
</head>

<body>

    <Navigation>
    </Navigation>

    <section class="intro" id="intro">

        <div class="headings">

            <h1 class="italic">Semii</h1>
            <h2>Technology Creative</h2>

        </div>

        <img src="../meInAHoody.jpg" style="width: 15%"
            alt="giant ti-84 vertical to the sky in a new york street saying hi">

        <p>
            Hi!
            <br>
            I'm Semii! I love programming, biking, and
            <br>
            learning new things!
        </p>
    </section>

    <section class="project" id="project">
        <h1 class="headings ">Projects</h1>

        <Card title="This Webpage" description="Portfolio site made from scratch to show off projects"
            technologiesUsed="The technologies used: html, JavaScript, CSS, bootstrap, github pages and, formsubmit api"
            photoPath="../../demogif1.gif" />

    </section>

    <section class="resume" id="resume">

        <h1 class="headings">Find Me On The Web</h1>


        <div class="buttonContainer">
            <ButtonComp link='../../Resume.pdf' text="resume" />
            <ButtonComp link='https://github.com/DestineeAdams' text="github" />
        </div>
    </section>

    <section class="contact" id="contact">
        <div>

            <h1 class="headings "> Say Hello</h1>
            
            <form>
            </form>

        </div>
    </section>


    <footer>

    </footer>
</body>


</html>


<style>
    body {
        margin: auto;
        font: san;
        text-align: center;
        background-color: #242323;
        color: #ffffff
    }

    img {
        margin: auto;
    }

    footer {
        margin: 10%;
    }
</style>