---
import Card from '../components/Card.astro';
import ButtonComp from '../components/ButtonComp.astro';

---


<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <link rel="shortcut icon" type="image/jpg" href="../public/favicon.ico" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-rbsA2VBKQhggwzxH7pPCaAqO46MgnOM80zW1RWuH61DGLwZJEdK2Kadq2F9CUG65" crossorigin="anonymous">

    <script src="https://code.iconify.design/iconify-icon/1.0.2/iconify-icon.min.js"></script>

    <title>semii dot space</title>
</head>

<body>

    <section class="intro">

        <h1>Semii</h1>

        <h2>Technology Creative</h2>

        <img src="../public/meInAHoody.jpg" style="width: 15%"
            alt="giant ti-84 vertical to the sky in a new york street saying hi">

        <p>
            Hi!
            <br>
            I'm Semii! I love programming, biking, and
            <br>
            learning new things!
        </p>
    </section>


    <section class="project">
        <h1 class="headings " id="projects">Projects</h1>

        <Card title="This Webpage" description="Portfolio site made from scratch to show off projects"
            technologiesUsed="The technologies used: html, JavaScript, CSS, bootstrap, github pages and, formsubmit api"
            photoPath="../../public/demogif1.gif" />

    </section>



    <section class="resume">

        <h1 class="headings">Find Me On The Web</h1>


        <div>
            <ButtonComp link='../../Resume.pdf' text="resume" color="#ffffff" />
            <ButtonComp link='https://github.com/DestineeAdams' text="github" color="#ffffff" />
        </div>
    </section>

    <section class="contact">

        <div>

            <h1> Say Hello</h1>

            <form target="_blank" action="https://formsubmit.co/adestinee37@gmail.com" method="POST">

                <input type="text" name="name" class="form-control" placeholder="Full Name" required>
                <input type="email" name="email" class="form-control" placeholder="Email Address" required>
                <textarea placeholder="Your Message" class="form-control" name="message" rows="5" cols="40"
                    required></textarea>

                <button type="submit">Submit Form</button>

            </form>
        </div>
    </section>

</body>


</html>


<style>

    img {
        border-radius: 10px;
    }
    body {
        background-color: #212529;
        color: #ffffff;
        text-align: center;

    }

    button {
        background-color: Transparent;
        margin: 5%;
        padding: 2% 5%;
        text-align: center;
        text-decoration: none;
        display: inline-block;
        font-size: 15px;
        border-radius: 5px;

        border: 2px solid #ffffff;
        color: #ffffff;

    }

    button:hover {
        background-color: #ffffff;
        color: #212529;
        text-decoration: none;
    }

    section {
        margin-top: 5%;
        margin-bottom: 5%;
    }

    form {
        padding: 1% 35%;
    }
</style>