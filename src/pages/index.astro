---
import Card from '../components/Card.astro';
import ButtonComp from '../components/ButtonComp.astro';
import navigationbar from '../components/navigationbar.astro';

---

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <!-- <link rel="shortcut icon" type="ico" href="favicon.ico" /> -->

    <title>semii dot space</title>
</head>

<body>

    <navigationbar />
    
<nav>
    <ul>
        <li class="nav-item"> <a class="nav-link" style="color: #ffffff" href="#">Intro</a></li>

        <li class="nav-item"> <a class="nav-link" style="color: #ffffff" href="#projects">Projects</a> </li>

        <li class="nav-item"> <a class="nav-link" style="color: #ffffff" href="#resume">Resume</a> </li>

        <li class="nav-item"> <a class="nav-link" style="color: #ffffff" href="#contact">Contact</a> </li>

        <li class="nav-item"> <a class="nav-link" style="color: #ffffff" href="blog">Blog</a> </li>

        <li class="nav-item"> <a class="nav-link" style="color: #ffffff" href="art">Art</a> </li>
    </ul>

</nav>


    <section class="intro">

        <div class="headings">

            <h1 class="italic">Semii</h1>
            <h2>Technology Creative</h2>

        </div>

        <img src="../meInAHoody.jpg" style="width: 15%"
            alt="giant ti-84 vertical to the sky in a new york street saying hi">

        <p>
            Hi!
            <br>
            I'm Semii! I love programming, biking, and
            <br>
            learning new things!
        </p>
    </section>


    <section class="project">
        <h1 class="headings ">Projects</h1>

        <Card title="This Webpage" description="Portfolio site made from scratch to show off projects"
            technologiesUsed="The technologies used: html, JavaScript, CSS, bootstrap, github pages and, formsubmit api"
            photoPath="../../demogif1.gif" />

    </section>



    <section class="resume">

        <h1 class="headings">Find Me On The Web</h1>


        <div class="buttonContainer">
            <ButtonComp link='../../Resume.pdf' text="resume"  />
            <ButtonComp link='https://github.com/DestineeAdams' text="github"  />
        </div>
    </section>

    <section class="contact">

        <div>

            <h1 class="headings "> Say Hello</h1>

            <form target="_blank" action="https://formsubmit.co/adestinee37@gmail.com" method="POST">

                <input type="text" name="name" class="form-control" placeholder="Full Name" required>
                <input type="email" name="email" class="form-control" placeholder="Email Address" required>
                <textarea placeholder="Your Message" class="form-control" name="message" rows="5" cols="40"
                    required></textarea>

                <button type="submit">Submit Form</button>

            </form>
        </div>
    </section>

</body>


</html>


<style>
    img {
        border-radius: 10px;
    }

    body {
        background-color: #212529;
        color: #ffffff;
        text-align: center;

    }

    button {
        background-color: Transparent;
        margin: 5%;
        padding: 2% 5%;
        text-align: center;
        text-decoration: none;
        display: inline-block;
        font-size: 15px;
        border-radius: 5px;

        border: 2px solid #ffffff;
        color: #ffffff;

    }

    button:hover {
        background-color: #ffffff;
        color: #212529;
        text-decoration: none;
    }

    section {
        margin-top: 5%;
        margin-bottom: 5%;
    }

    form {
        padding: 1% 30%;
    }

    .buttonContainer {
        margin-top: 5%;
    }

    .headings {
        margin-bottom: 5%;
    }

    img {
        margin-bottom: 5%;
    }
</style>